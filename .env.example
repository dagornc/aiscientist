# AI Scientist — Environment Variables
# Copy this file to .env and fill in your API keys.

# ── API Keys ──────────────────────────────────────────────
APP_API_KEY=
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
GEMINI_API_KEY=

# ── Literature Search ────────────────────────────────────────
S2_API_KEY=
OPENALEX_MAIL_ADDRESS=

# ── Pexels API (for frontend images) ─────────────────────────
PEXELS_API_KEY=ZnlkUkUXWmU8c952I25mt7uICdv7vnW5USCfb0M7Itz6qE8iJ9UAUC0e

# ── Application ──────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=false
APP_LOG_LEVEL=INFO

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=sqlite:///./data/autosearch.db

# ── Sandbox ──────────────────────────────────────────────────
SANDBOX_ENABLED=true
SANDBOX_TIMEOUT=300

# ── LLM Defaults ─────────────────────────────────────────────
LLM_PROVIDER=openrouter
LLM_MODEL=nvidia/nemotron-3-super-120b-a12b:free
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096
