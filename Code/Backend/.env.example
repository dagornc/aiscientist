# API KEYS
APP_API_KEY=
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Literature Search
S2_API_KEY=your_semantic_scholar_api_key_here  # Optional but recommended
OPENALEX_MAIL_ADDRESS=your_email@domain.com   # Optional but recommended

# Application Configuration
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=false
APP_LOG_LEVEL=INFO

# LLM Configuration
LLM_PROVIDER=openrouter
LLM_MODEL=openrouter/nvidia/nemotron-3-super-120b-a12b:free
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096
LLM_RETRY_ATTEMPTS=3
LLM_RETRY_DELAY=1.0
LLM_RETRY_BACKOFF=2.0

# Sandbox Configuration
SANDBOX_ENABLED=true
SANDBOX_TIMEOUT=600
SANDBOX_CPU_LIMIT=2.0
SANDBOX_MEMORY_LIMIT=4g
SANDBOX_NETWORK_DISABLED=true

# Database Configuration
DATABASE_URL=sqlite:///./ai_scientist.db

# LaTeX Configuration
LATEX_COMPILER=pdflatex
LATEX_TEMPLATES_DIR=templates/latex
LATEX_OUTPUT_FORMAT=pdf

# CORS Settings
ALLOWED_ORIGINS=["http://localhost:3000", "http://localhost:8000"]